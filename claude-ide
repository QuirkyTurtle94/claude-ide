#!/usr/bin/env bash
set -euo pipefail

SESSION="claude-ide"
DSP=""
DIR=""

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --dsp) DSP="--dangerously-skip-permissions" ;;
        -h|--help)
            echo "Usage: claude-ide [DIR] [OPTIONS]"
            echo ""
            echo "Launch a tmux IDE session with yazi, Claude Code, and two terminal panes."
            echo ""
            echo "Arguments:"
            echo "  DIR          Working directory (default: current directory)"
            echo ""
            echo "Options:"
            echo "  --dsp        Launch Claude with --dangerously-skip-permissions"
            echo "  -h, --help   Show this help message"
            exit 0
            ;;
        *) DIR="$arg" ;;
    esac
done

DIR="${DIR:-.}"
DIR="$(cd "$DIR" && pwd)"

# If session exists, attach and exit
if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach-session -t "$SESSION"
fi

# Create session with the center pane (Claude Code)
tmux new-session -d -s "$SESSION" -c "$DIR" -x "$(tput cols)" -y "$(tput lines)"

# Split left pane for yazi (~33% width)
tmux split-window -h -b -l 33% -t "$SESSION" -c "$DIR"
tmux send-keys -t "$SESSION" "yazi '$DIR'" Enter

# Select the right (main) pane and split right column (~50% of remaining = 33% of total)
tmux select-pane -t "$SESSION:.1"
tmux split-window -h -l 50% -t "$SESSION" -c "$DIR"

# Split right column into two terminal panes
tmux split-window -v -l 50% -t "$SESSION" -c "$DIR"

# Go back to center pane and launch Claude
tmux select-pane -t "$SESSION:.1"
tmux send-keys -t "$SESSION" "claude $DSP" Enter

# Attach
exec tmux attach-session -t "$SESSION"
